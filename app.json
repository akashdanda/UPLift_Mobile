{
  "expo": {
    "name": "Uplift",
    "slug": "UPLift",
    "version": "1.5.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "uplift",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.akashdanda.uplift",
      "buildNumber": "21",
      "usesAppleSignIn": true
    },
    "android": {
      "package": "com.akashdanda.uplift",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Uplift to access your photos for profile and workout images.",
          "cameraPermission": "Allow Uplift to use the camera to capture workout progress photos and reaction selfies that you choose to share with friends and groups."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Uplift to use the camera to capture workout progress photos and reaction selfies shared in the app."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-blank.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#8A88E3"
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow Uplift to read phone numbers from your contacts so we can suggest friends who are already on Uplift."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
